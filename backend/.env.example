# Step 1: Get from aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Step 2: Get from Firebase service account
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY="your_private_key"
FIREBASE_CLIENT_EMAIL=your_client_email

# Step 3: Blockchain (Polygon Amoy)
DEPLOYER_PRIVATE_KEY=your_metamask_private_key
CONTRACT_ADDRESS=your_deployed_contract_address

# Step 4: Web3.Storage (Optional: For server-side persistent uploads)
# If these are missing, it will use local agent (requires 'w3 login' on server)
# W3_PRINCIPAL=
# W3_PROOF=

PORT=5000
